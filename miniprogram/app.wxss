/* 全局样式 */
page {
  background: #f0f2f5;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  color: #1a1a2e;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16px;
  box-shadow: 0 2px 20px rgba(0,0,0,0.06);
  padding: 28px 24px;
  margin: 12px 16px;
}

.card-header {
  text-align: center;
  margin-bottom: 8px;
}

.card-header .title {
  font-size: 22px;
  font-weight: 700;
  background: linear-gradient(135deg, #667eea, #764ba2);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.card-header .subtitle {
  color: #888;
  font-size: 13px;
  margin-top: 4px;
}

/* 按钮通用 */
.btn-primary {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  padding: 14px 40px;
  border: none;
  border-radius: 14px;
  font-size: 16px;
  font-weight: 600;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-primary[disabled] {
  opacity: 0.35;
}

.btn-secondary {
  background: #f0f2f5;
  color: #444;
  padding: 12px 28px;
  border: none;
  border-radius: 12px;
  font-size: 14px;
}
