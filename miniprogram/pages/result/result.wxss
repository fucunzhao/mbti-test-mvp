.page-result {
  padding-bottom: 32px;
}

.result-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 110px;
  height: 110px;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 32px;
  font-weight: 800;
  letter-spacing: 4px;
  margin: 12px auto;
  box-shadow: 0 6px 28px rgba(102,126,234,0.3);
}

.result-type {
  font-size: 26px;
  font-weight: 700;
  margin-bottom: 2px;
}

.result-name {
  font-size: 16px;
  color: #667eea;
  font-weight: 600;
  margin-bottom: 16px;
}

.dim-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin: 14px 0 18px;
  text-align: left;
}

.dim-box {
  background: #f8f9ff;
  border-radius: 12px;
  padding: 12px 14px;
}

.dl {
  font-size: 11px;
  color: #888;
  margin-bottom: 3px;
}

.dv {
  font-size: 15px;
  font-weight: 700;
}

.dd {
  font-size: 11px;
  color: #666;
  margin-top: 1px;
}

.desc-box {
  text-align: left;
  background: #f8f9ff;
  border-radius: 14px;
  padding: 18px 20px;
  line-height: 1.8;
  font-size: 14px;
  color: #444;
  margin-bottom: 14px;
}

/* 支付区域 */
.pay-section {
  margin-top: 4px;
}

.pay-divider {
  height: 1px;
  background: #f0f0f0;
  margin: 16px 0;
}

.pay-info {
  margin-bottom: 14px;
}

.pay-icon {
  font-size: 28px;
  display: block;
  margin-bottom: 6px;
}

.pay-title {
  font-size: 16px;
  font-weight: 700;
  display: block;
  margin-bottom: 4px;
}

.pay-desc {
  font-size: 13px;
  color: #888;
  display: block;
}

.pay-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  padding: 14px 0;
  border-radius: 14px;
  font-size: 16px;
  font-weight: 600;
  text-align: center;
  margin-bottom: 6px;
}

.pay-btn.disabled {
  opacity: 0.6;
}

.pay-note {
  font-size: 11px;
  color: #aaa;
  margin-bottom: 4px;
}

.unlocked-badge {
  font-size: 14px;
  color: #52c41a;
  font-weight: 600;
  padding: 8px 0;
  margin-bottom: 8px;
}

.btn-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 8px;
}

.btn-secondary {
  background: #f0f2f5;
  color: #444;
  padding: 12px 0;
  border-radius: 12px;
  font-size: 14px;
  text-align: center;
}
