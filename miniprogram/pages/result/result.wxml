<view class="page-result">
  <view class="card" style="text-align:center">
    <!-- 结果徽章 -->
    <view class="result-badge">{{resultType}}</view>
    <view class="result-type">{{resultType}}</view>
    <view class="result-name">「{{resultName}}」</view>

    <!-- 四维分数 -->
    <view class="dim-grid">
      <block wx:for="{{dimResults}}" wx:key="dim">
        <view class="dim-box" style="background: {{item.isLeft ? '#eef0ff' : '#f8f9ff'}}">
          <view class="dl">{{item.dim}}</view>
          <view class="dv" style="color: {{item.isLeft ? '#667eea' : '#764ba2'}}">{{item.letter}} | {{item.score}}/{{item.total}}</view>
          <view class="dd">{{item.isLeft ? item.leftLabel : item.rightLabel}}</view>
        </view>
      </block>
    </view>

    <!-- 结果描述 -->
    <view class="desc-box">
      <text>{{resultDesc}}</text>
    </view>

    <!-- 解锁/支付区域 -->
    <view wx:if="{{!isPaid}}" class="pay-section">
      <view class="pay-divider"></view>
      <view class="pay-info">
        <text class="pay-icon">🔓</text>
        <text class="pay-title">查看完整人格分析报告</text>
        <text class="pay-desc">详细解读 + 职业建议 + 人际关系指南</text>
      </view>
      <view class="pay-btn {{paying ? 'disabled' : ''}}" bindtap="doPay">
        <text wx:if="{{!paying}}">¥0.99 解锁完整报告</text>
        <text wx:if="{{paying}}">支付处理中...</text>
      </view>
      <view class="pay-note">仅需支付一次，永久查看</view>
    </view>

    <!-- 已解锁提示 -->
    <view wx:if="{{isPaid}}" class="unlocked-badge">✅ 已解锁完整报告</view>

    <!-- 按钮组 -->
    <view class="btn-group">
      <view class="btn-primary" bindtap="goHome">🔄 重新测试</view>
      <view class="btn-secondary" bindtap="shareResult">📤 分享结果</view>
    </view>
  </view>
</view>
