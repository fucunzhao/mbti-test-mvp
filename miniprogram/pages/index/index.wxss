.page-welcome {
  padding-bottom: 32px;
}

.hero {
  padding: 16px 0;
}

.emoji {
  font-size: 56px;
  margin-bottom: 12px;
}

.hero-title {
  font-size: 20px;
  font-weight: 700;
  display: block;
  margin-bottom: 8px;
}

.hero-desc {
  color: #666;
  font-size: 14px;
  line-height: 1.8;
  display: block;
  white-space: pre-line;
}

.mode-grid {
  display: flex;
  gap: 16px;
  margin: 20px 0;
}

.mode-card {
  flex: 1;
  border: 2px solid #e8e8e8;
  border-radius: 16px;
  padding: 24px 20px;
  text-align: center;
  transition: all 0.2s;
}

.mode-card:active {
  border-color: #667eea;
  transform: translateY(-2px);
}

.mode-card .icon {
  font-size: 36px;
  margin-bottom: 8px;
}

.mode-name {
  font-size: 16px;
  font-weight: 600;
  display: block;
  margin-bottom: 4px;
}

.mode-desc {
  font-size: 13px;
  color: #888;
  display: block;
  line-height: 1.6;
}

.time-badge {
  display: inline-block;
  border-radius: 20px;
  font-size: 12px;
  padding: 3px 10px;
  margin-top: 8px;
}

.time-badge.quick {
  background: #eef0ff;
  color: #667eea;
}

.time-badge.full {
  background: #f3eef9;
  color: #764ba2;
}

.history-card {
  background: #fff;
  border-radius: 16px;
  box-shadow: 0 2px 20px rgba(0,0,0,0.06);
  padding: 20px 24px;
  margin: 12px 16px;
}

.history-title {
  font-size: 15px;
  font-weight: 600;
  color: #444;
  margin-bottom: 12px;
  display: block;
}

.history-empty {
  color: #aaa;
  font-size: 13px;
  text-align: center;
  padding: 12px 0;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 10px 0;
  border-bottom: 1px solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.rtype {
  font-weight: 700;
  font-size: 15px;
  color: #667eea;
}

.rname {
  font-size: 13px;
  color: #666;
  margin-left: 6px;
}

.rtime {
  font-size: 12px;
  color: #888;
}
