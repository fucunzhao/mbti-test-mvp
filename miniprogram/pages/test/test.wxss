.page-test {
  padding-bottom: 32px;
}

.steps {
  display: flex;
  justify-content: center;
  gap: 4px;
  margin-bottom: 20px;
  flex-wrap: wrap;
}

.step {
  width: 12px;
  height: 4px;
  border-radius: 2px;
  background: #e0e0e0;
  transition: all 0.3s;
}

.step.active {
  background: linear-gradient(90deg, #667eea, #764ba2);
  width: 20px;
}

.step.done {
  background: #667eea;
}

.dim-tag {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 10px;
  font-size: 11px;
  font-weight: 600;
  margin-bottom: 14px;
}

.dim-ei { background: #e8f4f8; color: #1a7a9e; }
.dim-sn { background: #f0e8f8; color: #6a3a9e; }
.dim-tf { background: #fef3e2; color: #b06a1a; }
.dim-jp { background: #e8f8ec; color: #1a8a3a; }

.story-box {
  background: #f8f9ff;
  border-radius: 14px;
  padding: 20px;
  margin-bottom: 20px;
  border-left: 4px solid #667eea;
}

.story-box .label {
  font-size: 11px;
  color: #667eea;
  font-weight: 600;
  letter-spacing: 1px;
  margin-bottom: 6px;
}

.story-text {
  font-size: 15px;
  line-height: 1.8;
  color: #333;
}

.options {
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-bottom: 20px;
}

.opt {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  padding: 14px 16px;
  border: 2px solid #e8e8e8;
  border-radius: 12px;
  background: #fff;
  font-size: 14px;
  line-height: 1.6;
  color: #333;
  transition: all 0.2s;
}

.opt:active {
  border-color: #667eea;
  background: #f8f9ff;
}

.opt.selected {
  border-color: #667eea;
  background: #eef0ff;
}

.opt .key {
  flex-shrink: 0;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  background: #f0f2f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 12px;
  color: #666;
}

.opt.selected .key {
  background: #667eea;
  color: #fff;
}

.opt-text {
  flex: 1;
  word-break: break-word;
}

.nav-row {
  display: flex;
  gap: 10px;
  justify-content: space-between;
  align-items: center;
}

.btn {
  padding: 11px 24px;
  border-radius: 12px;
  font-size: 14px;
  font-weight: 600;
  text-align: center;
}

.btn-prev {
  background: #f0f2f5;
  color: #666;
}

.btn-prev:active {
  background: #e0e0e0;
}

.btn-prev.hidden {
  visibility: hidden;
}

.btn-next {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  flex: 1;
  max-width: 180px;
  margin-left: auto;
}

.btn-next:active {
  opacity: 0.9;
}

.btn-next.disabled {
  opacity: 0.35;
}

.progress-bar {
  background: #fff;
  border-radius: 16px;
  padding: 12px 24px;
  margin: 12px 16px;
  text-align: center;
  font-size: 12px;
  color: #aaa;
}
